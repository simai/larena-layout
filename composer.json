{
  "name": "larena/layout",
  "description": "Larena Layout: Universal layout and page composition engine for public pages, admin pages, dashboards, forms, lists, detail pages, documentation pages and widgets in Larena.",
  "type": "library",
  "license": "Apache-2.0",
  "authors": [
    {
      "name": "Rim Zabarov",
      "homepage": "https://github.com/zabarov"
    }
  ],
  "require": {
    "php": "^8.3"
  },
  "autoload": {
    "psr-4": {
      "Larena\\Layout\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Larena\\Layout\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0"
  },
  "scripts": {
    "test": "php -d zend.assertions=1 -d assert.exception=1 scripts/run-unit-tests.php",
    "test:unit": "php -d zend.assertions=1 -d assert.exception=1 scripts/run-unit-tests.php",
    "lint": "php scripts/lint.php",
    "analyse": "php scripts/analyse.php",
    "validate:larena": "php scripts/validate-larena-package.php",
    "evidence:check": "php scripts/check-evidence.php",
    "scope:check": "php tools/larena-scope-check.php",
    "quality:gate": [
      "@validate:larena",
      "@lint",
      "@analyse",
      "@test",
      "@evidence:check",
      "@scope:check"
    ]
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {}
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
